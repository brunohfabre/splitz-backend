// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String?
  bio        String?
  avatar_url String?
  created_at DateTime @default(now())

  friends    Friend[] @relation("user")
  friends_in Friend[] @relation("friend")

  bills Bill[]

  @@map("users")
}

model Friend {
  id          String    @id @default(uuid())
  accepted_at DateTime?
  created_at  DateTime  @default(now())

  user_id   String?
  user      User?   @relation("user", fields: [user_id], references: [id], onDelete: SetNull)
  friend_id String?
  friend    User?   @relation("friend", fields: [friend_id], references: [id], onDelete: SetNull)

  @@map("friends")
}

model Bill {
  id          String   @id @default(uuid())
  name        String
  total_value Float
  created_at  DateTime @default(now())

  billUsers BillUser[]

  owner_id String
  owner    User   @relation(fields: [owner_id], references: [id])

  @@map("bills")
}

model BillUser {
  id         String   @id @default(uuid())
  value      Float
  user_id    String
  created_at DateTime @default(now())

  bill    Bill   @relation(fields: [bill_id], references: [id], onDelete: Cascade)
  bill_id String

  @@map("bill_users")
}
